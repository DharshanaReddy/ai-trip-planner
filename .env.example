# ── LLM ─────────────────────────────────────────────────────────────
# Get a free key at console.groq.com (no credit card required)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# ── LangSmith observability ──────────────────────────────────────────
# Free tier at smith.langchain.com — enables full 4-agent trace view
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=ai-trip-planner
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Caching ──────────────────────────────────────────────────────────
# Leave empty to use in-memory dict cache (dev default)
# Set to redis://localhost:6379 for persistent caching
REDIS_URL=

# ── App ──────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
APP_ENV=development
